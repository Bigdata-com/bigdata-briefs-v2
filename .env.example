# ── Required ──────────────────────────────────────────────────────────────────
BIGDATA_API_KEY=<your-bigdata-api-key>
OPENAI_API_KEY=<your-openai-api-key>

# ── Optional ──────────────────────────────────────────────────────────────────

# Max entities processed in parallel (default: 10)
# MAX_CONCURRENT_ENTITIES=10

# SQLite database path (default: briefs.db next to pyproject.toml)
# Override when running in Docker with a mounted volume:
# DB_STRING=sqlite:////data/bigdata_briefs.db

# Directory where per-run debug JSON files are written (default: .brief_pipeline_state/)
# BRIEF_PIPELINE_STATE_DIR=

# LLM call timeout in seconds (default: 60)
# LLM_TIMEOUT_SECONDS=60

# Novelty lookback window in days (default: 14)
# NOVELTY_LOOKBACK_DAYS=14
